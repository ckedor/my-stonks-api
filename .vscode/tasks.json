{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start PostgreSQL (Docker)",
      "type": "shell",
      "command": "docker-compose up -d db",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Start Redis (Docker)",
      "type": "shell",
      "command": "docker-compose up -d redis",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Dependencies",
      "dependsOn": [
        "Start PostgreSQL (Docker)",
        "Start Redis (Docker)"
      ],
      "dependsOrder": "parallel"
    },
    {
      "label": "Frontend Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
